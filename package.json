{
  "author": "Hotay <hi@hotay.dev>",
  "contributors": [
    "TaylorHo <taylor@hotay.dev>"
  ],
  "bin": {
    "enygmah": "./bin/run.js"
  },
  "dependencies": {
    "@oclif/core": "^3",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.0.9",
    "@oclif/plugin-update": "^4",
    "@oclif/plugin-warn-if-update-available": "^3"
  },
  "description": "The only tool your project needs to guarantee security and quality. Open-source and free.",
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^3",
    "@types/chai": "^4",
    "@types/cli-progress": "^3.11.5",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "chai": "^4",
    "eslint": "^8",
    "eslint-config-oclif": "^5",
    "eslint-config-oclif-typescript": "^3",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "mocha": "^10",
    "oclif": "^4.1.3",
    "prettier": "^3.2.2",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/hotaydev/enygmah",
  "license": "AGPL-3.0",
  "main": "./bin/run.js",
  "name": "enygmah",
  "oclif": {
    "bin": "enygmah",
    "dirname": "enygmah",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-update",
      "@oclif/plugin-not-found"
    ],
    "topicSeparator": " "
  },
  "repository": "hotaydev/enygmah",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint --fix --ext .ts,.cjs,.js .",
    "lint:all": "eslint --fix .",
    "prettier": "prettier --write .",
    "format": "npm run prettier && npm run lint:all",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run format",
    "prepack": "npm run build && oclif manifest",
    "prepare": "husky install && npm run build",
    "test": "mocha --forbid-only \"test/**/*.test.ts\""
  },
  "version": "0.0.1",
  "bugs": "https://github.com/hotaydev/enygmah/issues",
  "keywords": [
    "security",
    "enygmah",
    "open-source",
    "quality",
    "code-security",
    "code-quality",
    "static-analysis",
    "dynamic-analysis",
    "code-analysis"
  ],
  "types": "dist/index.d.ts",
  "exports": "./lib/index.js",
  "type": "module"
}
