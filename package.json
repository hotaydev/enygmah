{
  "name": "enygmah",
  "version": "0.1.0",
  "description": "The only tool your project needs to guarantee security and quality. Open-source and free.",
  "main": "./bin/run.js",
  "license": "AGPL-3.0",
  "homepage": "https://enygmah.com",
  "repository": "https://github.com/hotaydev/enygmah",
  "bugs": "https://github.com/hotaydev/enygmah/issues",
  "author": "Hotay <hi@hotay.dev>",
  "contributors": [
    "TaylorHo <taylor@hotay.dev>"
  ],
  "bin": {
    "enygmah": "bin/dev.js"
  },
  "scripts": {
    "lint": "eslint --fix --ext .ts,.cjs,.js .",
    "lint:all": "eslint --fix .",
    "prettier": "prettier --write .",
    "format": "npm run prettier && npm run lint:all",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "docs": "typedoc",
    "prepare": "git config --local core.hooksPath .hooks/",
    "build": "tsc -b && oclif manifest",
    "clean": "shx rm -f oclif.manifest.json && shx rm -rf dist",
    "prepack": "npm run clean && npm run build && oclif manifest",
    "pack": "oclif pack tarballs --no-xz"
  },
  "dependencies": {
    "@oclif/core": "^3",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.0.9",
    "@oclif/plugin-update": "^4",
    "@oclif/plugin-warn-if-update-available": "^3",
    "inquirer": "^9.2.13"
  },
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^3",
    "@types/chai": "^4",
    "@types/cli-progress": "^3.11.5",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "chai": "^4",
    "eslint": "^8",
    "eslint-config-oclif": "^5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^48.0.2",
    "mocha": "^10",
    "oclif": "^4.1.3",
    "prettier": "^3.2.2",
    "semantic-release": "^23.0.0",
    "shx": "^0.3.4",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.7",
    "typedoc-material-theme": "^1.0.2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "oclif": {
    "bin": "enygmah",
    "dirname": "enygmah",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-not-found",
      "@oclif/plugin-update",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-help"
    ],
    "topicSeparator": " "
  },
  "keywords": [
    "security",
    "enygmah",
    "open-source",
    "quality",
    "code-security",
    "code-quality",
    "static-analysis",
    "dynamic-analysis",
    "code-analysis"
  ],
  "types": "dist/index.d.ts",
  "exports": "./lib/index.js",
  "type": "module"
}
